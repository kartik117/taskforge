NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/taskforge
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_EXPIRES_IN=1h
OTP_TTL_SECONDS=300
OTP_LENGTH=6
CORS_ORIGIN=http://localhost:3000

# Optional -- without these, OTPs are logged instead of emailed (see src/services/mailer.ts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
